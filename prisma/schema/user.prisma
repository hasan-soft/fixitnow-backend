model User {
    id                String             @id @default(uuid())
    name              String
    email             String             @unique
    password          String
    role              Role
    status            UserStatus         @default(ACTIVE)
    createdAt         DateTime           @default(now())
    updatedAt         DateTime           @updatedAt
    technicianProfile TechnicianProfile?
    bookings          Booking[]
    reviews           Review[]

    @@map("users")
}
